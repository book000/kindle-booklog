{
  "name": "kindle-booklog",
  "version": "3.0.0",
  "description": "Get Kindle works purchased at Amazon.co.jp and register them in Booklog.",
  "homepage": "https://github.com/book000/kindle-booklog",
  "bugs": {
    "url": "https://github.com/book000/kindle-booklog/issues"
  },
  "license": "MIT",
  "author": "Tomachi",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:book000/kindle-booklog.git"
  },
  "scripts": {
    "compile": "tsc -p .",
    "compile:test": "tsc -p . --noEmit",
    "clean": "rimraf dist output",
    "lint:prettier": "prettier --check src",
    "lint:tsc": "tsc",
    "fix:prettier": "prettier --write src",
    "preinstall": "npx only-allow pnpm",
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "fix": "run-z fix:prettier,fix:eslint",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.14.40",
    "@book000/node-utils": "1.24.196",
    "@types/node": "24.12.4",
    "@types/tar-stream": "3.1.4",
    "csv-parse": "6.2.1",
    "eslint": "10.4.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-promise": "7.3.0",
    "iconv-lite": "0.7.2",
    "otplib": "13.4.0",
    "prettier": "3.8.3",
    "puppeteer-core": "24.43.1",
    "run-z": "2.1.0",
    "tar-stream": "3.2.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.2.0+sha512.cdd7e34ea0d237bed3fa89e633185027e3ecdad98ce7453032f4d4d83c10cb7b85b9afe8534048ab0a3cc10228bdd5e32f5f622d05d66e58f46177fe5601eab1"
}
